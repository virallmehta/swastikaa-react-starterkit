# ------------------------------------------------------------------
# App
# ------------------------------------------------------------------
VITE_APP_NAME=My App
VITE_APP_URL=http://localhost:5173

# ------------------------------------------------------------------
# SEO / Social sharing
# ------------------------------------------------------------------
# Canonical production URL (no trailing slash) — used to build canonical
# links, sitemap.xml entries, and absolute OG/Twitter image URLs.
VITE_SITE_URL=https://example.com
VITE_SITE_DESCRIPTION=A production-ready React boilerplate for SaaS apps and websites.
# Default social preview image, relative to /public or an absolute URL.
VITE_DEFAULT_OG_IMAGE=/og-image.png
VITE_TWITTER_HANDLE=@yourhandle
# Used for the "organization"/"website" JSON-LD structured data.
VITE_ORGANIZATION_NAME=Your Company

# ------------------------------------------------------------------
# API (your own backend, e.g. Node/Express, Laravel, Django, etc.)
# ------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api
VITE_API_TIMEOUT=15000

# ------------------------------------------------------------------
# Headless WordPress (WP REST API or WPGraphQL)
# ------------------------------------------------------------------
VITE_WORDPRESS_API_URL=https://your-wp-site.com/wp-json/wp/v2
VITE_WORDPRESS_GRAPHQL_URL=https://your-wp-site.com/graphql

# ------------------------------------------------------------------
# Headless Wagtail (Wagtail API v2)
# ------------------------------------------------------------------
VITE_WAGTAIL_API_URL=https://your-wagtail-site.com/api/v2

# ------------------------------------------------------------------
# Auth
# ------------------------------------------------------------------
VITE_AUTH_TOKEN_KEY=app_access_token
VITE_AUTH_REFRESH_TOKEN_KEY=app_refresh_token

# ------------------------------------------------------------------
# Feature flags
# ------------------------------------------------------------------
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_ANALYTICS=false

# ------------------------------------------------------------------
# Third-party (optional)
# ------------------------------------------------------------------
VITE_GA_MEASUREMENT_ID=
VITE_SENTRY_DSN=
